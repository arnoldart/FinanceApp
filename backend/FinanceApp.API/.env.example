# Copy this file to .env and fill the real values.
# DO NOT commit .env to version control.

CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=localhost;Port=5432;Database=financeapp;Username=postgres;Password=replace_me;SSL Mode=Disable

JWT__KEY=replace_with_generated_64byte_base64_key
JWT__ISSUER=FinanceApp
JWT__AUDIENCE=FinanceAppUsers
JWT__EXPIREMINUTES=60

CORS__FRONTENDORIGINS__0=https://financeapp.arnoldartworks.com
CORS__DEVORIGINS__0=http://localhost:3000

APP__VERIFYEMAILURL=http://localhost:3000/email-verify

SMTP__HOST=smtp.gmail.com
SMTP__PORT=587
SMTP__EMAIL=your-email@gmail.com
SMTP__PASSWORD=your-app-password
